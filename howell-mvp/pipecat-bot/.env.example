# ── Bot Server ────────────────────────────────────────────────────────────────
# Shared secret between Next.js API route and this bot server
BOT_SERVER_SECRET=change-me-to-a-long-random-string
PORT=8080

# ── Daily.co ──────────────────────────────────────────────────────────────────
# Used by bot.py at runtime (injected by server.py per-session)
# DAILY_ROOM_URL=   (set per-session by server.py)
# DAILY_BOT_TOKEN=  (set per-session by server.py)

# ── AI Services ──────────────────────────────────────────────────────────────
# Claude 3.5 Sonnet — the ONLY LLM used (no Gemini anywhere)
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs — voice synthesis
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Simli — photorealistic lip-sync avatar
SIMLI_API_KEY=...
SIMLI_FACE_ID=cace3ef7-a4c4-425d-a8cf-a5358eb0c427

# Deepgram — speech-to-text
DEEPGRAM_API_KEY=...

# ── HRMS Callback ─────────────────────────────────────────────────────────────
# This secret must match INTERVIEW_CALLBACK_SECRET in your Next.js .env
# HRMS_CALLBACK_URL=   (set per-session by server.py)
# HRMS_CALLBACK_SECRET=(set per-session by server.py)
